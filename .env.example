# Application environment: local | dev | production
ENV=local

# HTTP server
SERVER_PORT=8080

# PostgreSQL connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=leegoo
DATABASE_PASSWORD=leegoo
DATABASE_DBNAME=leegoo
DATABASE_SSLMODE=disable

# PostgreSQL connection pool (zero = driver default)
DATABASE_MAX_OPEN_CONNECTIONS=4
DATABASE_MAX_IDLE_CONNECTIONS=2
DATABASE_CONNECTION_MAX_TIME=0
DATABASE_CONNECTION_IDLE_TIME=0

# JWT authentication
AUTH_JWT_SECRET=change-me-in-production
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=168h

# Logging level: debug | info | warn | error
LOG_LEVEL=info
